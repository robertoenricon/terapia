# ----------------------------------------------------------------------------
# Modelo de ambiente de PRODUÇÃO para a LocalWeb (Hospedagem compartilhada).
#
# Copie este arquivo para ".env" antes de enviar a aplicação ao servidor:
#     cp .env.production.example .env
#
# Em seguida preencha os valores marcados com "ALTERAR" usando os dados do
# painel da LocalWeb (domínio, banco MySQL e SMTP). NUNCA versione o ".env".
# ----------------------------------------------------------------------------

APP_NAME=Terapia
APP_ENV=production
# Gere a chave localmente com: php artisan key:generate --show
# e cole o valor (começa com "base64:") aqui.
APP_KEY=
APP_DEBUG=false
# URL pública do site (com https). Ex.: https://terapia.com.br
APP_URL=https://ALTERAR-seu-dominio.com.br

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Em produção registramos apenas erros (evita logs gigantes na hospedagem).
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Banco de dados MySQL criado no painel da LocalWeb ("Bancos de Dados MySQL" /
# DBaaS). Na LocalWeb o MySQL é remoto, então o host é algo como
# "terapia_diario.mysql.dbaas.com.br" (NÃO use "localhost").
DB_CONNECTION=mysql
DB_HOST=ALTERAR_host.mysql.dbaas.com.br
DB_PORT=3306
DB_DATABASE=ALTERAR_nome_do_banco
DB_USERNAME=ALTERAR_usuario_do_banco
DB_PASSWORD=ALTERAR_senha_do_banco

# Sessão, cache e fila ficam no banco (não há Redis na hospedagem
# compartilhada). SESSION_SECURE_COOKIE=true porque o site roda em https.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Credenciais do administrador criado pelo seeder (php artisan db:seed).
# Defina uma senha forte ANTES de semear o banco.
ADMIN_NAME=ALTERAR_admin
ADMIN_PASSWORD=ALTERAR_senha_forte

# E-mail (SMTP da LocalWeb). Ajuste host/porta conforme o painel.
# Porta 587 = TLS; porta 465 = SSL.
MAIL_MAILER=smtp
MAIL_HOST=email-ssl.com.br
MAIL_PORT=587
MAIL_USERNAME=ALTERAR_seu-email@seu-dominio.com.br
MAIL_PASSWORD=ALTERAR_senha_do_email
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="ALTERAR_seu-email@seu-dominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
