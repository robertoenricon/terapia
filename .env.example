# ----------------------------------------------------------------------------
# Variaveis usadas pelo docker-compose (nivel de infraestrutura).
# Copie para ".env" e ajuste conforme necessario:  cp .env.example .env
#
# Observacao: este arquivo NAO substitui o ".env" interno do Laravel
# (que fica em "src/.env"). Os valores de banco devem ser identicos nos dois.
# ----------------------------------------------------------------------------

# UID/GID do seu usuario no host (evita problemas de permissao em volumes).
# No Linux/macOS descubra com: id -u  e  id -g
UID=1000
GID=1000

# Porta em que a aplicacao ficara acessivel no host (http://localhost:8080).
NGINX_PORT=8080

# Configuracao do banco MySQL.
DB_PORT=3306
DB_DATABASE=semear
DB_USERNAME=semear
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root
